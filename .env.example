# Copy this file to .env and fill in the values from your Firebase project.
# See README.md "Firebase setup" for exact step-by-step instructions on
# where to find each of these in the Firebase console.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
